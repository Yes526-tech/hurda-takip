@model FireHurdaTakip.Models.HurdaKayit
@{
    ViewData["Title"] = "Yeni Kayıt Gir";
}

<div class="container mt-4">
    <h3 class="text-center mb-4">Akü ve Plastik Fire Girişi</h3>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success border-0 rounded-4 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-check-circle-fill me-2" viewBox="0 0 16 16">
              <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
            </svg>
            @TempData["Message"]
        </div>
    }

    <form asp-controller="Hurda" asp-action="Ekle" method="post">
        
        <div class="mb-3">
            <label asp-for="Tarih" class="form-label">Tarih</label>
            <input asp-for="Tarih" type="date" class="form-control" required value="@DateTime.Today.ToString("yyyy-MM-dd")">
            <span asp-validation-for="Tarih" class="text-danger"></span>
        </div>

        <div class="card mb-4 border-0 shadow-sm">
            <div class="card-header bg-warning text-dark d-flex align-items-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-battery-half me-2" viewBox="0 0 16 16">
                  <path d="M2 6h10v4H2V6z"/>
                  <path d="M2 4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H2zm10 1a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h10zm4 3a1.5 1.5 0 0 1-1.5 1.5v-3A1.5 1.5 0 0 1 16 8z"/>
                </svg>
                Akümülatör Hurdaları
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="AlinanSiparisNo" class="form-label">Alınan Sipariş No</label>
                    <input asp-for="AlinanSiparisNo" type="text" class="form-control">
                </div>
                <div class="mb-3">
                    <label asp-for="AkumulatorHurdasiKg" class="form-label">Akümülatör Hurdası (KG)</label>
                    <input asp-for="AkumulatorHurdasiKg" type="number" step="0.01" class="form-control" value="0">
                </div>
            </div>
        </div>

        <div class="card mb-4 border-0 shadow-sm">
            <div class="card-header bg-info text-white d-flex align-items-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-recycle me-2" viewBox="0 0 16 16">
                  <path d="M9.302 1.256a1.5 1.5 0 0 0-2.604 0l-1.704 2.98a.5.5 0 0 0 .869.497l1.703-2.981a.5.5 0 0 1 .868 0l2.54 4.444-1.256-.337a.5.5 0 1 0-.26.966l2.415.647a.5.5 0 0 0 .613-.353l.647-2.415a.5.5 0 1 0-.966-.259l-.333 1.242-2.532-4.431zM2.973 7.773l-1.255.337a.5.5 0 1 1-.26-.966l2.416-.647a.5.5 0 0 1 .612.353l.647 2.415a.5.5 0 0 1-.966.259l-.333-1.242-2.545 4.454a.5.5 0 0 0 .434.748H5a.5.5 0 0 1 0 1H1.723A1.5 1.5 0 0 1 .421 12.24l2.552-4.467zm10.89 1.463a.5.5 0 1 0-.868.496l1.716 3.004a.5.5 0 0 1-.434.748h-5.57l.647-.646a.5.5 0 1 0-.708-.707l-1.5 1.5a.498.498 0 0 0 0 .707l1.5 1.5a.5.5 0 1 0 .708-.707l-.647-.647h5.57a1.5 1.5 0 0 0 1.302-2.244l-1.716-3.004z"/>
                </svg>
                Plastik Hurdalar
            </div>
            <div class="card-body">
                 <div class="mb-3">
                    <label asp-for="IzabeyeGonderilenHurdaKg" class="form-label">İzabeye Gönderilen (KG)</label>
                    <input asp-for="IzabeyeGonderilenHurdaKg" type="number" step="0.01" class="form-control" value="0">
                </div>
                <div class="mb-3">
                    <label asp-for="PEnjeksiyonaGonderilenHurdaKg" class="form-label">P. Enjeksiyona Gönderilen (KG)</label>
                    <input asp-for="PEnjeksiyonaGonderilenHurdaKg" type="number" step="0.01" class="form-control" value="0">
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-success w-100 btn-lg mb-5 shadow-sm d-flex justify-content-center align-items-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-cloud-arrow-up-fill me-2" viewBox="0 0 16 16">
              <path d="M8 2a5.53 5.53 0 0 0-3.594 1.342c-.766.66-1.321 1.52-1.464 2.383C1.266 6.095 0 7.555 0 9.318 0 11.366 1.708 13 3.781 13h8.906C14.502 13 16 11.57 16 9.773c0-1.636-1.242-2.969-2.834-3.194C12.923 3.999 10.69 2 8 2zm2.354 5.146a.5.5 0 0 1-.708.708L8.5 6.707V10.5a.5.5 0 0 1-1 0V6.707L6.354 7.854a.5.5 0 1 1-.708-.708l2-2a.5.5 0 0 1 .708 0l2 2z"/>
            </svg>
            Sisteme Güvenle Kaydet
        </button>
    </form>
</div>
