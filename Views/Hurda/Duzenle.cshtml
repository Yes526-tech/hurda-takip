@model FireHurdaTakip.Models.HurdaKayit
@{
    ViewData["Title"] = "Kaydı Düzenle";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8 col-xl-7">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-primary mb-2">Kayıt Düzenle</h2>
            <p class="text-muted">Seçtiğiniz hurda kaydını güncelleyin</p>
        </div>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success border-0 glass-card shadow-sm d-flex align-items-center mb-4">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                @TempData["Message"]
            </div>
        }

        <form asp-controller="Hurda" asp-action="Duzenle" method="post" class="glass-card p-4 p-md-5">
            <input type="hidden" asp-for="Id" />
            
            <div class="form-floating mb-4">
                <input asp-for="Tarih" type="date" class="form-control" required placeholder="Tarih" value="@Model.Tarih.ToString("yyyy-MM-dd")">
                <label asp-for="Tarih">Kayıt Tarihi</label>
                <span asp-validation-for="Tarih" class="text-danger small mt-1"></span>
            </div>

            <div class="card mb-4 border-0 bg-transparent">
                <div class="card-header bg-warning bg-opacity-10 text-warning-emphasis border-warning border-opacity-25 border rounded-top-3 d-flex align-items-center py-3">
                    <i class="bi bi-battery-half fs-5 me-2 text-warning"></i>
                    <h5 class="mb-0 fw-semibold">Akümülatör Hurdaları</h5>
                </div>
                <div class="card-body bg-white bg-opacity-50 border border-top-0 rounded-bottom-3 border-warning border-opacity-25">
                    <div class="form-floating mb-3">
                        <input asp-for="AlinanSiparisNo" type="text" class="form-control" placeholder="Sipariş No">
                        <label asp-for="AlinanSiparisNo">Alınan Sipariş No</label>
                    </div>
                    <div class="form-floating">
                        <input asp-for="AkumulatorHurdasiKg" type="number" step="0.01" class="form-control" placeholder="Akü Hurdası">
                        <label asp-for="AkumulatorHurdasiKg">Akümülatör Hurdası (KG)</label>
                    </div>
                </div>
            </div>

            <div class="card mb-5 border-0 bg-transparent">
                <div class="card-header bg-info bg-opacity-10 text-info-emphasis border-info border-opacity-25 border rounded-top-3 d-flex align-items-center py-3">
                    <i class="bi bi-recycle fs-5 me-2 text-info"></i>
                    <h5 class="mb-0 fw-semibold">Plastik Hurdalar</h5>
                </div>
                <div class="card-body bg-white bg-opacity-50 border border-top-0 rounded-bottom-3 border-info border-opacity-25">
                     <div class="form-floating mb-3">
                        <input asp-for="IzabeyeGonderilenHurdaKg" type="number" step="0.01" class="form-control" placeholder="İzabe">
                        <label asp-for="IzabeyeGonderilenHurdaKg">İzabeye Gönderilen (KG)</label>
                    </div>
                    <div class="form-floating">
                        <input asp-for="PEnjeksiyonaGonderilenHurdaKg" type="number" step="0.01" class="form-control" placeholder="P. Enjeksiyon">
                        <label asp-for="PEnjeksiyonaGonderilenHurdaKg">P. Enjeksiyona Gönderilen (KG)</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3">
                <a asp-action="Index" class="btn btn-light shadow-sm py-3 px-4 flex-grow-1 fw-bold text-muted border">
                    İptal Et
                </a>
                <button type="submit" class="btn-custom-primary flex-grow-1 py-3 shadow-sm d-flex justify-content-center align-items-center gap-2 fs-5">
                    <i class="bi bi-save-fill"></i>
                    Değişiklikleri Kaydet
                </button>
            </div>
        </form>
    </div>
</div>
