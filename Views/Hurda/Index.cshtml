@model IEnumerable<FireHurdaTakip.Models.HurdaKayit>
@{
    ViewData["Title"] = "Hurda Kayıtları";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h3>@ViewData["Title"]</h3>
        <div class="d-flex gap-2 align-items-center">
            <form asp-action="UploadAndUpdateExcel" method="post" enctype="multipart/form-data" class="d-flex align-items-center m-0">
                <input type="file" name="excelFile" class="form-control form-control-sm me-2" accept=".xlsx" required title="Mevcut Excel şablonunuzu seçin" />
                <button type="submit" class="btn btn-success btn-sm text-nowrap d-flex align-items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-upload" viewBox="0 0 16 16">
                      <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                      <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708l3-3z"/>
                    </svg>
                    Şablonu Güncelle
                </button>
            </form>
            <div class="vr mx-1"></div>
            <a asp-action="ExcelExport" class="btn btn-primary btn-sm d-flex align-items-center gap-1 text-nowrap">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-excel" viewBox="0 0 16 16">
                    <path d="M5.884 6.68a.5.5 0 1 0-.768.64L7.349 10l-2.233 2.68a.5.5 0 0 0 .768.64L8 10.781l2.116 2.54a.5.5 0 0 0 .768-.641L8.651 10l2.233-2.68a.5.5 0 0 0-.768-.64L8 9.219l-2.116-2.54z"/>
                    <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2zM9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5v2z"/>
                </svg>
                Sıfırdan İndir
            </a>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">
            @TempData["Message"]
        </div>
    }

    <div class="table-responsive mt-3">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Tarih</th>
                    <th>Toplam Plastik Hurdası (KG)</th>
                    <th>Alınan Sipariş No</th>
                    <th>Akümülatör Hurdası (KG)</th>
                    <th>İzabeye Gönderilen (KG)</th>
                    <th>P. Enjeksiyona Gönderilen (KG)</th>
                    <th>Ay</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td data-label="Tarih">@item.Tarih.ToString("dd.MM.yyyy")</td>
                        <td data-label="Plastik Hurdası">@item.ToplamPlastikHurdasiKg <span class="text-muted small">KG</span></td>
                        <td data-label="Sipariş No"><span class="badge bg-light text-dark border">@item.AlinanSiparisNo</span></td>
                        <td data-label="Akü Hurdası">@item.AkumulatorHurdasiKg <span class="text-muted small">KG</span></td>
                        <td data-label="İzabe Gönderilen">@item.IzabeyeGonderilenHurdaKg <span class="text-muted small">KG</span></td>
                        <td data-label="P. Enjeksiyon">@item.PEnjeksiyonaGonderilenHurdaKg <span class="text-muted small">KG</span></td>
                        <td data-label="Ay">@item.Ay. Ay</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">Henüz hiç kayıt bulunmuyor.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
