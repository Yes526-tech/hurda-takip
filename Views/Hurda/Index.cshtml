@model IEnumerable<FireHurdaTakip.Models.HurdaKayit>
@{
    ViewData["Title"] = "Hurda Kayıtları";
}

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h3 class="fw-bold mb-0 text-primary d-flex align-items-center gap-2">
            <i class="bi bi-stack"></i> @ViewData["Title"]
        </h3>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <form asp-action="UploadAndUpdateExcel" method="post" enctype="multipart/form-data" class="d-flex align-items-center m-0 glass-card px-2 py-1">
                <input type="file" name="excelFile" class="form-control form-control-sm me-2 border-0 bg-transparent shadow-none" accept=".xlsx" required title="Mevcut Excel şablonunuzu seçin" style="max-width: 200px;"/>
                <button type="submit" class="btn-custom-success btn-sm text-nowrap d-flex align-items-center gap-1">
                    <i class="bi bi-cloud-arrow-up"></i>
                    Şablonu Güncelle
                </button>
            </form>
            <a asp-action="ExcelExport" class="btn-custom-primary btn-sm d-flex align-items-center gap-1 text-nowrap py-2">
                <i class="bi bi-file-earmark-excel"></i>
                Sıfırdan İndir
            </a>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success border-0 glass-card shadow-sm d-flex align-items-center">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            @TempData["Message"]
        </div>
    }

    <div class="table-responsive-custom mt-4">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th>Tarih</th>
                    <th>Toplam Plastik</th>
                    <th>Sipariş No</th>
                    <th>Akü Hurdası</th>
                    <th>İzabe Gönderilen</th>
                    <th>P. Enjeksiyon</th>
                    <th>Ay</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td data-label="Tarih">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-calendar3 text-muted"></i>
                                @item.Tarih.ToString("dd.MM.yyyy")
                            </div>
                        </td>
                        <td data-label="Toplam Plastik">
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-2 py-1 rounded-pill">
                                @item.ToplamPlastikHurdasiKg KG
                            </span>
                        </td>
                        <td data-label="Sipariş No"><span class="fw-medium text-dark">@item.AlinanSiparisNo</span></td>
                        <td data-label="Akü Hurdası">@item.AkumulatorHurdasiKg <span class="text-muted small">KG</span></td>
                        <td data-label="İzabe">@item.IzabeyeGonderilenHurdaKg <span class="text-muted small">KG</span></td>
                        <td data-label="P. Enjeksiyon">@item.PEnjeksiyonaGonderilenHurdaKg <span class="text-muted small">KG</span></td>
                        <td data-label="Ay">@item.Ay. Ay</td>
                        <td data-label="İşlemler" class="actions-cell text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Duzenle" asp-route-id="@item.Id" class="btn btn-sm btn-light border shadow-sm text-primary btn-icon rounded-circle" title="Düzenle">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                <form asp-action="Sil" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu kaydı silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-sm btn-light border shadow-sm text-danger btn-icon rounded-circle" title="Sil">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                            Henüz hiç kayıt bulunmuyor.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
