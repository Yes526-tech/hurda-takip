<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AKO Hurda Takip</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FireHurdaTakip.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-custom mb-4">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Hurda" asp-action="Index">
                    <i class="bi bi-recycle fs-3 text-primary"></i>
                    <span>AKO Hurda Takip</span>
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Hurda" asp-action="Index">
                                <i class="bi bi-list-task me-1"></i> Kayıtlar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Hurda" asp-action="Ekle">
                                <i class="bi bi-plus-circle me-1"></i> Yeni Ekle
                            </a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="nav-link text-warning cursor-pointer" style="cursor:pointer;" data-bs-toggle="modal" data-bs-target="#calculatorModal">
                                <i class="bi bi-calculator-fill me-1"></i> Hesap Makinesi
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Calculator Modal -->
    <div class="modal fade" id="calculatorModal" tabindex="-1" aria-labelledby="calculatorModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content glass-card border-0 shadow-lg" style="background: rgba(255, 255, 255, 0.95);">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold text-primary" id="calculatorModalLabel"><i class="bi bi-calculator"></i> Hesap Makinesi</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="calculator-wrapper">
                        <div class="calc-display mb-3 rounded-3 p-3 text-end fw-bold shadow-inner" id="calcDisplay">0</div>
                        <div class="calc-grid">
                            <button class="calc-btn btn-action" onclick="calcClear()">C</button>
                            <button class="calc-btn btn-action" onclick="calcDelete()">⌫</button>
                            <button class="calc-btn btn-op" onclick="calcAppend('%')">%</button>
                            <button class="calc-btn btn-op" onclick="calcAppend('/')">÷</button>

                            <button class="calc-btn btn-num" onclick="calcAppend('7')">7</button>
                            <button class="calc-btn btn-num" onclick="calcAppend('8')">8</button>
                            <button class="calc-btn btn-num" onclick="calcAppend('9')">9</button>
                            <button class="calc-btn btn-op" onclick="calcAppend('*')">×</button>

                            <button class="calc-btn btn-num" onclick="calcAppend('4')">4</button>
                            <button class="calc-btn btn-num" onclick="calcAppend('5')">5</button>
                            <button class="calc-btn btn-num" onclick="calcAppend('6')">6</button>
                            <button class="calc-btn btn-op" onclick="calcAppend('-')">−</button>

                            <button class="calc-btn btn-num" onclick="calcAppend('1')">1</button>
                            <button class="calc-btn btn-num" onclick="calcAppend('2')">2</button>
                            <button class="calc-btn btn-num" onclick="calcAppend('3')">3</button>
                            <button class="calc-btn btn-op" onclick="calcAppend('+')">+</button>

                            <button class="calc-btn btn-num span-2" onclick="calcAppend('0')">0</button>
                            <button class="calc-btn btn-num" onclick="calcAppend('.')">.</button>
                            <button class="calc-btn btn-equals shadow-sm" onclick="calcCalculate()">=</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="footer-custom mt-auto">
        <div class="container d-flex flex-column align-items-center justify-content-center">
            <span class="mb-1">&copy; @DateTime.Now.Year - AKO Hurda Takip Sistemi</span>
            <div class="fw-bold fs-6 mt-1 d-flex align-items-center gap-2">
                <span class="text-muted fw-normal" style="font-size: 0.85rem;">Designed & Developed by</span> 
                <span style="background: linear-gradient(90deg, #FF0080, #7928CA); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-shadow: 0px 2px 10px rgba(121, 40, 202, 0.2);">Yunus Emre Sert</span>
                <i class="bi bi-lightning-charge-fill" style="color: #FF0080;"></i>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
