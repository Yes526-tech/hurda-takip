{
  "hosting": {
    "public": "wwwroot",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "fire-hurda-takip",
          "region": "europe-west1"
        }
      }
    ]
  }
}
